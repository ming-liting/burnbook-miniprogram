<!-- 个人中心 iPhone 29 -->
<view class="pg">
  <view class="top">
    <image class="av" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}"/>
    <view class="av ph" wx:else>👤</view>
    <text class="nm">{{nickName}}</text>
    <text class="sub">燃本·记录每一滴汗水</text>
  </view>
  <view class="menu">
    <view class="mi" bindtap="onMenu" data-t="favorites"><text class="ml">⭐ 我的收藏</text><text class="ma">›</text></view>
    <view class="mi" bindtap="onMenu" data-t="settings"><text class="ml">⚙️ 设置</text><text class="ma">›</text></view>
    <view class="mi" bindtap="onMenu" data-t="help"><text class="ml">❓ 帮助与反馈</text><text class="ma">›</text></view>
    <view class="mi" bindtap="onMenu" data-t="about"><text class="ml">📋 关于燃本</text><text class="ma">›</text></view>
  </view>
  <view class="out" bindtap="onLogout"><text>退出登录</text></view>
  <view class="nav"><view class="n" bindtap="onNav" data-t="home">🏠<text>首页</text></view><view class="n" bindtap="onNav" data-t="training">⏱️<text>训练</text></view><view class="n" bindtap="onNav" data-t="record">📋<text>记录</text></view><view class="n on">👤<text>我的</text></view></view>
</view>
