<!-- 训练进度详情 - 记录第2页 -->
<view class="pg">
  <!-- 顶部：左头像+名称，右日期 -->
  <view class="head">
    <view class="hl">
      <image class="av" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}"/>
      <view class="av ph" wx:else>👤</view>
      <text class="nm">{{nickName}}</text>
    </view>
    <text class="dt">{{today}}</text>
  </view>

  <!-- 消耗卡路里周曲线 -->
  <view class="card">
    <text class="ct">消耗卡路里峰值</text>
    <view class="bars">
      <view class="bar" wx:for="{{weekBars}}" wx:key="d">
        <view class="bf" style="height:{{item.h}}rpx"></view>
        <text class="bv" wx:if="{{item.v}}">{{item.v}}</text>
        <text class="bd">{{item.d}}</text>
      </view>
    </view>
  </view>

  <!-- 训练部位统计 -->
  <view class="card">
    <text class="ct">训练部位统计</text>
    <view class="parts">
      <view class="pi" wx:for="{{parts}}" wx:key="name">
        <text class="pn">{{item.name}}</text>
        <text class="pc">{{item.count}}次</text>
        <view class="pb"><view class="pf" style="width:{{item.pct}}%"></view></view>
        <text class="pp">{{item.pct}}%</text>
      </view>
    </view>
  </view>

  <view class="nav"><view class="n" bindtap="onNav" data-t="home">🏠<text>首页</text></view><view class="n" bindtap="onNav" data-t="training">⏱️<text>训练</text></view><view class="n on">📋<text>记录</text></view><view class="n" bindtap="onNav" data-t="profile">👤<text>我的</text></view></view>
</view>
