.pg{width:100vw;min-height:100vh;background:#1E1E1E}
.top{display:flex;flex-direction:column;align-items:center;padding:160rpx 40rpx 48rpx}
.av{width:140rpx;height:140rpx;border-radius:50%;border:4rpx solid #E2F163;margin-bottom:20rpx}
.av.ph{display:flex;align-items:center;justify-content:center;font-size:64rpx;background:#333}
/* 木林 20px Roboto Bold */
.nm{font-weight:700;font-size:40rpx;color:#FFF;margin-bottom:8rpx}
/* 燃本·记录每一滴汗水 12px Roboto Bold */
.sub{font-weight:700;font-size:24rpx;color:#888}
.menu{padding:0 40rpx}
.mi{display:flex;justify-content:space-between;align-items:center;padding:36rpx 0;border-bottom:1rpx solid rgba(255,255,255,.06)}
/* 我的收藏/设置 15px Roboto Bold */
.ml{font-weight:700;font-size:30rpx;color:#FFF}
.ma{font-size:36rpx;color:#555}
.out{margin:80rpx 40rpx;padding:36rpx;background:rgba(255,68,68,.08);border-radius:24rpx;text-align:center}
/* 退出登录 13px Roboto Bold */
.out text{font-weight:700;font-size:26rpx;color:#FF4444}
.nav{position:fixed;bottom:0;left:0;width:100%;background:#1A1A1A;display:flex;justify-content:space-around;padding:16rpx 0 48rpx;z-index:999;border-top:1rpx solid rgba(255,255,255,.06)}
.n{display:flex;flex-direction:column;align-items:center;gap:6rpx;font-size:40rpx;opacity:.4}
.n text{font-size:22rpx}.n.on{opacity:1;color:#E2F163}

