.pg{width:100vw;min-height:100vh;background:#1E1E1E;padding-bottom:200rpx}
.top{display:flex;justify-content:space-between;align-items:center;padding:160rpx 32rpx 24rpx}
.time{font-weight:700;font-size:64rpx;color:#E2F163}
.end{padding:16rpx 28rpx;background:linear-gradient(135deg,#896CFE,#B3A0FF);border-radius:200rpx;font-size:24rpx;color:#FFF}
.list{padding:0 32rpx}
.ex{background:rgba(255,255,255,.05);border-radius:20rpx;padding:24rpx;margin-bottom:16rpx}
.ex.on{border:2rpx solid #E2F163}
.ex.ok{opacity:.45}
.exh{display:flex;align-items:center;gap:12rpx}
.exi{width:40rpx;height:40rpx;border-radius:50%;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:22rpx;color:#999}
.exn{flex:1;font-weight:600;font-size:28rpx;color:#FFF}
.exb{padding:8rpx 24rpx;border-radius:200rpx;font-size:22rpx}
.exb.pending{background:#896CFE;color:#FFF}
.exb.doing{background:#E2F163;color:#1E1E1E}
.exb.done{background:rgba(255,255,255,.08);color:#666}
.sets{margin-top:16rpx;padding-top:16rpx;border-top:1rpx solid rgba(255,255,255,.06)}
.sr{display:flex;align-items:center;gap:8rpx;margin-bottom:8rpx}
.si{width:40rpx;height:40rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20rpx;border:2rpx solid rgba(255,255,255,.2);color:#999}
.si.cu{border-color:#E2F163;color:#E2F163}
.si.ck{background:#896CFE;border-color:#896CFE;color:#FFF}
.sio{flex:1;height:50rpx;background:rgba(255,255,255,.08);border-radius:8rpx;font-size:22rpx;color:#FFF;text-align:center}
.sc{width:44rpx;height:44rpx;border-radius:50%;border:2rpx solid #E2F163;display:flex;align-items:center;justify-content:center;color:#E2F163;font-size:20rpx}
.sc.ok{background:#896CFE;border-color:#896CFE;color:#FFF}
.bot{position:fixed;bottom:0;left:0;width:100%;padding:24rpx 40rpx 48rpx;background:#1A1A1A}
.adde{width:100%;height:88rpx;background:linear-gradient(135deg,#896CFE,#B3A0FF);border-radius:200rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx;color:#FFF}
.rest{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:200}
.rt{font-size:32rpx;color:#999;margin-bottom:24rpx}
.rn{font-weight:700;font-size:120rpx;color:#E2F163;margin-bottom:40rpx}
.rc{display:flex;gap:32rpx}
.rb{padding:16rpx 28rpx;background:rgba(255,255,255,.1);border-radius:200rpx;font-size:24rpx;color:#FFF}
.rsk{padding:16rpx 40rpx;background:#896CFE;border-radius:200rpx;font-size:24rpx;color:#FFF}
.em{position:fixed;bottom:-1200rpx;left:0;width:100%;background:#2A2A2A;border-radius:40rpx 40rpx 0 0;padding:48rpx 48rpx 80rpx;z-index:300;transition:.3s}
.em.on{bottom:0}
.emt{display:block;font-weight:700;font-size:40rpx;color:#FFF;text-align:center}
.ems{display:block;font-size:26rpx;color:#999;text-align:center;margin:16rpx 0 32rpx}
.emi{width:100%;height:80rpx;background:rgba(255,255,255,.08);border-radius:16rpx;text-align:center;font-size:28rpx;color:#FFF;margin-bottom:40rpx}
.emb{display:flex;gap:24rpx}
.ebc{flex:1;height:88rpx;background:rgba(255,255,255,.1);border-radius:200rpx;display:flex;align-items:center;justify-content:center;color:#999}
.ebd{flex:2;height:88rpx;background:linear-gradient(135deg,#896CFE,#B3A0FF);border-radius:200rpx;display:flex;align-items:center;justify-content:center;color:#FFF;font-weight:700}

