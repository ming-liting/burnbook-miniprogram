<!-- 训练入口 -->
<view class="page">
  <text class="date">{{month}}月{{day}}日</text>
  <text class="week">星期{{weekDay}}</text>
  <view class="row"><text class="hero">开始撸铁吧！</text><view class="hist-btn" bindtap="onHistory"><text>历史 ›</text></view></view>
  <text class="slogan">记录每一滴汗水！</text>
  <view class="go-btn" bindtap="onGo"><text>开始记录</text></view>
  <view class="tpl"><text class="tpl-t">模板广场</text><text class="tpl-s">敬请期待</text></view>
  <view class="nav">
    <view class="n" bindtap="onNav" data-t="home">🏠<text>首页</text></view>
    <view class="n on">⏱️<text>训练</text></view>
    <view class="n" bindtap="onNav" data-t="record">📋<text>记录</text></view>
    <view class="n" bindtap="onNav" data-t="profile">👤<text>我的</text></view>
  </view>
</view>
