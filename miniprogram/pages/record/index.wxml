<!-- 数据概览 - 记录第1页 -->
<view class="pg">
  <!-- 本周概览 -->
  <view class="card">
    <text class="ct">本周概览</text>
    <view class="row">
      <view class="st"><text class="sv">{{weekDays}}</text><text class="sl">运动天数</text></view>
      <view class="st"><text class="sv">{{weekKcal}}</text><text class="sl">消耗卡路里</text></view>
      <view class="st"><text class="sv">{{weekMin}}</text><text class="sl">运动时长</text></view>
    </view>
  </view>

  <!-- 简约周日历 -->
  <view class="cal">
    <view class="day" wx:for="{{week}}" wx:key="d">
      <text class="dn">{{item.day}}</text>
      <text class="dd">{{item.date}}</text>
      <view class="dot" wx:if="{{item.active}}"></view>
    </view>
  </view>

  <!-- 训练进度按钮 -->
  <view class="btn" bindtap="onProgress"><text>训练进度</text></view>

  <view class="nav"><view class="n" bindtap="onNav" data-t="home">🏠<text>首页</text></view><view class="n" bindtap="onNav" data-t="training">⏱️<text>训练</text></view><view class="n on">📋<text>记录</text></view><view class="n" bindtap="onNav" data-t="profile">👤<text>我的</text></view></view>
</view>
