.login-page { width: 100vw; min-height: 100vh; background: #FFFFFF; position: relative; }
.gradient-top { width: 100%; height: 500rpx; background: linear-gradient(180deg, #896CFE 0%, #B3A0FF 40%, #FFFFFF 100%); position: absolute; top: 0; left: 0; }
.content { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; padding: 160rpx 64rpx 0; }
.brand-logo { font-weight: 700; font-size: 36rpx; color: #FFFFFF; letter-spacing: 8rpx; margin-bottom: 12rpx; }
.brand-sub { font-weight: 400; font-size: 26rpx; color: rgba(255,255,255,0.85); margin-bottom: 100rpx; }

.auth-section { display: flex; flex-direction: column; align-items: center; width: 100%; }
.auth-title { font-weight: 700; font-size: 48rpx; color: #1E1E1E; margin-bottom: 20rpx; }
.auth-desc { font-weight: 400; font-size: 28rpx; color: #999; margin-bottom: 60rpx; }

/* 旧版按钮 */
.auth-btn { width: 100%; height: 100rpx; border-radius: 200rpx; background: linear-gradient(135deg, #896CFE, #B3A0FF); display: flex; align-items: center; justify-content: center; border: none; padding: 0; }
.auth-btn::after { border: none; }
.auth-btn-text { font-weight: 700; font-size: 34rpx; color: #FFFFFF; letter-spacing: 4rpx; }

/* 新版头像授权 */
.new-auth { width: 100%; display: flex; flex-direction: column; align-items: center; }
.avatar-btn { width: 180rpx; height: 180rpx; border-radius: 50%; background: rgba(137,108,254,0.1); display: flex; flex-direction: column; align-items: center; justify-content: center; border: 4rpx dashed #896CFE; padding: 0; margin-bottom: 40rpx; }
.avatar-btn::after { border: none; }
.avatar-preview { width: 176rpx; height: 176rpx; border-radius: 50%; }
.avatar-placeholder { font-size: 64rpx; }
.avatar-tip { font-size: 22rpx; color: #896CFE; margin-top: -16rpx; }

.nickname-wrap { width: 100%; margin-bottom: 48rpx; }
.nickname-label { display: block; font-weight: 500; font-size: 28rpx; color: #666; margin-bottom: 16rpx; }
.nickname-input { width: 100%; height: 90rpx; background: #F3F3F3; border-radius: 30rpx; padding: 0 32rpx; font-size: 30rpx; color: #1E1E1E; }

.enter-btn { width: 100%; height: 100rpx; border-radius: 200rpx; background: linear-gradient(135deg, #896CFE, #B3A0FF); display: flex; align-items: center; justify-content: center; }
.enter-btn-text { font-weight: 700; font-size: 34rpx; color: #FFFFFF; letter-spacing: 8rpx; }

.auth-notice { font-weight: 400; font-size: 22rpx; color: #BBB; margin-top: 32rpx; text-align: center; }
